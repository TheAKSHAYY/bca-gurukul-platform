# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/_/settings/api

# Public URL of your Supabase project
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Public anon key (safe to expose to browser)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Server-side variables (do NOT expose to browser)
# Keep these secret in your production environment
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
SUPABASE_PROJECT_ID=your-project-id
